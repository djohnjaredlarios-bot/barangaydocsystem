{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE"
  },
  "deploy": {
    "startCommand": "sh -c 'gunicorn app:app --chdir backend --bind 0.0.0.0:${PORT:-5000} --workers 4 --threads 2 --timeout 60'",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowMs": 60000
  }
}
